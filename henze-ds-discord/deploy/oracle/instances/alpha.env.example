# Copy to /opt/henze-discord/runtime/instances/alpha.env on the VM
# Keep this file on the VM only; never commit real secrets.

DISCORD_TOKEN=replace-with-alpha-token
DISCORD_CHANNEL_ID=replace-with-channel-id
OPENAI_API_KEY=replace-with-openai-key

# Optional tuning
CRON_SCHEDULE="0 0 8 * * *"
SETTLEMENT_INTERVAL_SECS=300
DATABASE_PATH=/data/henze_bets.db
