<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Henze DS - Bet Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Henze DS</a>
        </div>
    </nav>

    <div class="container py-4">
        <header class="text-center mb-4">
            <h1 class="display-5 fw-bold text-primary">Bet Finder</h1>
            <p class="lead text-muted">Find bets with specific odds ranges</p>
        </header>

        <div class="card shadow-sm mb-4 card-dark">
            <div class="card-body">
                <form method="post" action="/" class="row g-3 align-items-end justify-content-center">
                    <div class="col-auto">
                        <label for="target" class="form-label fw-semibold">Target Odds</label>
                        <input type="number" class="form-control" id="target" name="target" 
                               value="{{ target }}" step="0.01" min="1.01" max="10" 
                               placeholder="e.g., 1.10">
                    </div>
                    <div class="col-auto">
                        <label for="tolerance" class="form-label fw-semibold">Tolerance (+/-)</label>
                        <input type="number" class="form-control" id="tolerance" name="tolerance" 
                               value="{{ tolerance }}" step="0.01" min="0.01" max="1" 
                               placeholder="e.g., 0.04">
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-secondary">
                            <i class="bi bi-search me-1"></i> Find Bets
                        </button>
                    </div>
                </form>
                <div class="text-center mt-3 pt-3 border-top">
                    <span class="text-muted">Searching odds range:</span>
                    <span class="fw-bold text-secondary ms-2">{{ min_odds | round(precision=2) }} - {{ max_odds | round(precision=2) }}</span>
                </div>
            </div>
        </div>

        {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Error:</strong> {{ error }}
        </div>
        {% endif %}

        <div class="card shadow-sm card-dark">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-table me-2"></i>Results</h5>
                <span class="badge bg-secondary">{{ count }} bet{% if count != 1 %}s{% endif %} found</span>
            </div>
            <div class="card-body p-0">
                {% if bets | length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0" id="bets-table">
                        <thead class="table-light">
                            <tr>
                                <th class="sortable" data-sort="event">Event <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                <th class="sortable" data-sort="time">Time <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                <th class="sortable" data-sort="market">Market <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                <th class="sortable" data-sort="outcome">Outcome <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                <th class="sortable" data-sort="odds">Odds <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for bet in bets %}
                            <tr>
                                <td data-label="Event"><a href="{{ bet.event_url }}" target="_blank" class="event-link">{{ bet.event_name }} <i class="bi bi-box-arrow-up-right small"></i></a></td>
                                <td data-label="Time">{{ bet.event_time }}</td>
                                <td data-label="Market">{{ bet.market_name }}</td>
                                <td data-label="Outcome">{{ bet.outcome }}</td>
                                <td data-label="Odds" class="fw-bold text-success">{{ bet.decimal | round(precision=2) }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                    <p class="mb-1">No bets found matching your criteria.</p>
                    <small>Try adjusting the target odds or increasing the tolerance.</small>
                </div>
                {% endif %}
            </div>
        </div>

        <footer class="text-center mt-4 pt-3 border-top">
            <a href="/api/bets?target={{ target }}&tolerance={{ tolerance }}" target="_blank" class="text-decoration-none">
                <i class="bi bi-braces me-1"></i> API Endpoint (JSON)
            </a>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/script.js"></script>
</body>
</html>
