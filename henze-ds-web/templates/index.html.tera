<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Henze DS - Bet Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    

    <div class="container py-4">
        <header class="text-center mb-4">
            <h1 class="display-5 fw-bold text-primary">Bet Finder</h1>
            <p class="lead text-muted">Find bets with specific odds ranges</p>
        </header>

        <div class="card shadow-sm mb-4 card-dark">
            <div class="card-body">
                <form method="post" action="/" class="row g-3 align-items-end justify-content-center">
                    <div class="col-auto">
                        <label for="target" class="form-label fw-semibold">Target Odds</label>
                        <input type="number" class="form-control" id="target" name="target" 
                               value="{{ target }}" step="0.01" min="1.01" max="10" 
                               placeholder="e.g., 1.10">
                    </div>
                    <div class="col-auto">
                        <label for="tolerance" class="form-label fw-semibold">Tolerance (+/-)</label>
                        <input type="number" class="form-control" id="tolerance" name="tolerance" 
                               value="{{ tolerance }}" step="0.01" min="0.01" max="1" 
                               placeholder="e.g., 0.04">
                    </div>
                    <div class="col-auto">
                        <label for="sport" class="form-label fw-semibold">Sport</label>
                        <select class="form-select" id="sport" name="sport">
                            {% for s in sports %}
                            <option value="{{ s.id }}" {% if s.selected %}selected{% endif %}>{{ s.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div class="col-auto">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-secondary fw-semibold">
                                <i class="bi bi-search me-1"></i> Find Bets
                            </button>
                            <button type="button" id="feeling-lucky" class="btn btn-success fw-semibold">
                                <i class="bi bi-shuffle me-1"></i> Feeling Lucky
                            </button>
                        </div>
                    </div>
                </form>
                <div class="text-center mt-3 pt-3 border-top">
                    <span class="text-muted">Searching odds range:</span>
                    <span class="fw-bold text-secondary ms-2">{{ min_odds | round(precision=2) }} - {{ max_odds | round(precision=2) }}</span>
                    <span class="text-muted ms-3">|</span>
                    <span class="text-muted ms-3">Times shown in UTC+2</span>
                </div>
            </div>
        </div>

        {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Error:</strong> {{ error }}
        </div>
        {% endif %}

        <div class="card shadow-sm card-dark">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Events</h5>
                <span class="badge bg-secondary">{{ event_count }} event{% if event_count != 1 %}s{% endif %} ({{ count }} market{% if count != 1 %}s{% endif %})</span>
            </div>
            <div class="card-body p-0">
                {% if grouped_events | length > 0 %}
                <div class="accordion accordion-flush" id="eventsAccordion">
                    {% for event in grouped_events %}
                    <div class="accordion-item {% if event.is_live %}live-event{% endif %}">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed {% if event.is_live %}live-header{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#event-{{ event.event_id }}" aria-expanded="false">
                                <div class="event-header-content">
                                    <div class="event-info">
                                        {% if event.is_live %}
                                        <span class="live-badge me-2">
                                            <i class="bi bi-circle-fill pulse me-1"></i>LIVE
                                            {% if event.match_minute %}<span class="match-minute">{{ event.match_minute }}'</span>{% endif %}
                                        </span>
                                        {% endif %}
                                        <span class="sport-badge me-2">{{ event.sport_name }}</span>
                                        <a href="{{ event.event_url }}" target="_blank" class="event-link" onclick="event.stopPropagation()">
                                            {{ event.event_name }} <i class="bi bi-box-arrow-up-right small"></i>
                                        </a>
                                    </div>
                                    <div class="event-meta">
                                        <span class="event-time">
                                            <i class="bi bi-clock me-1"></i>{{ event.event_time }}
                                        </span>
                                        <span class="market-count badge bg-secondary ms-2">
                                            {{ event.markets | length }} market{% if event.markets | length != 1 %}s{% endif %}
                                        </span>
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="event-{{ event.event_id }}" class="accordion-collapse collapse" data-bs-parent="#eventsAccordion">
                            <div class="accordion-body p-0">
                                <table class="table table-sm table-striped mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Market</th>
                                            <th>Outcome</th>
                                            <th class="text-end">Odds</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for market in event.markets %}
                                        <tr data-event-id="{{ event.event_id }}" data-market-name="{{ market.market_name | escape }}" data-outcome="{{ market.outcome | escape }}" data-decimal="{{ market.decimal }}">
                                            <td>{{ market.market_name }}</td>
                                            <td>{{ market.outcome }}</td>
                                            <td class="text-end fw-bold text-success">{{ market.decimal | round(precision=2) }}</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                    <p class="mb-1">No bets found matching your criteria.</p>
                    <small>Try adjusting the target odds or increasing the tolerance.</small>
                </div>
                {% endif %}
            </div>
        </div>

        <footer class="text-center mt-4 pt-3 border-top">
            <a href="/api/bets?target={{ target }}&tolerance={{ tolerance }}{% if selected_sport %}&sport={{ selected_sport }}{% endif %}" target="_blank" class="text-decoration-none">
                <i class="bi bi-braces me-1"></i> API Endpoint (JSON)
            </a>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/script.js"></script>
</body>
</html>
