<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Henze DS - Bet Finder</title>
    <link rel="icon" type="image/svg+xml" href="/static/dice.svg">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <!-- Toast Container -->
    <div id="toast-container" class="toast-container"></div>

    <div class="container py-4">
        <header class="text-center mb-4">
            <h1 class="display-5 fw-bold text-primary">Bet Finder</h1>
            <p class="lead text-muted">Find bets with specific odds ranges</p>
        </header>

        <div class="card shadow-sm mb-4 card-dark">
            <div class="card-body">
                <form method="post" action="/" class="row g-3 align-items-end justify-content-center" id="filter-form">
                    <div class="col-auto">
                        <label for="target" class="form-label fw-semibold">Target Odds</label>
                        <input type="number" class="form-control" id="target" name="target" 
                               value="{{ target }}" step="0.01" min="1.01" max="10" 
                               placeholder="e.g., 1.10">
                    </div>
                    <div class="col-auto">
                        <label for="tolerance" class="form-label fw-semibold">Tolerance (+/-)</label>
                        <input type="number" class="form-control" id="tolerance" name="tolerance" 
                               value="{{ tolerance }}" step="0.01" min="0.01" max="1" 
                               placeholder="e.g., 0.04">
                    </div>
                    <div class="col-auto">
                        <label for="sport" class="form-label fw-semibold">Sport</label>
                        <select class="form-select" id="sport" name="sport">
                            {% for s in sports %}
                            <option value="{{ s.id }}" {% if s.selected %}selected{% endif %}>{{ s.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div class="col-auto">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-gold fw-semibold">
                                <i class="bi bi-search me-1"></i> Find Bets
                            </button>
                            <button type="button" id="feeling-lucky" class="btn btn-success fw-semibold">
                                <i class="bi bi-shuffle me-1"></i> Feeling Lucky
                            </button>
                        </div>
                    </div>
                </form>
                
                <!-- Advanced Filters Section -->
                <div class="mt-3 pt-3 border-top">
                    <button class="btn btn-sm btn-outline-secondary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFilters" aria-expanded="false" aria-controls="advancedFilters" id="advanced-filters-toggle">
                        <i class="bi bi-sliders me-1"></i> Advanced Filters
                        <span id="active-filter-count" class="badge bg-primary ms-2" style="display: none;">0</span>
                        <i class="bi bi-chevron-down ms-1 toggle-icon"></i>
                    </button>
                    
                    <div class="collapse mt-3" id="advancedFilters">
                        <div class="row g-3">
                            <!-- Time Filters Column -->
                            <div class="col-md-6">
                                <div class="card card-filter">
                                    <div class="card-header py-2">
                                        <h6 class="mb-0"><i class="bi bi-clock me-1"></i> Time Filters</h6>
                                    </div>
                                    <div class="card-body">
                                        <!-- Time Range Dropdown -->
                                        <div class="mb-3">
                                            <label for="time-preset-select" class="form-label fw-semibold small">Time Range</label>
                                            <select class="form-select form-select-sm" id="time-preset-select">
                                                <option value="all" selected>All Times</option>
                                                <option value="next2h">Next 2 Hours</option>
                                                <option value="today">Today</option>
                                                <option value="tomorrow">Tomorrow</option>
                                                <option value="week">This Week</option>
                                                <option value="custom">Custom Range...</option>
                                            </select>
                                            
                                            <!-- Custom Time Range Inputs -->
                                            <div id="custom-time-range" class="mt-2" style="display: none;">
                                                <div class="row g-2">
                                                    <div class="col-6">
                                                        <label class="form-label small">From</label>
                                                        <input type="datetime-local" class="form-control form-control-sm" id="from-time-input">
                                                    </div>
                                                    <div class="col-6">
                                                        <label class="form-label small">To</label>
                                                        <input type="datetime-local" class="form-control form-control-sm" id="to-time-input">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Event Status Filter -->
                                        <div class="mb-0">
                                            <label class="form-label fw-semibold small">
                                                <i class="bi bi-broadcast me-1"></i> Event Status
                                            </label>
                                            <div class="btn-group w-100" role="group">
                                                <input type="radio" class="btn-check" name="live_status" id="status-all" value="all" checked>
                                                <label class="btn btn-outline-secondary btn-sm" for="status-all">All</label>
                                                
                                                <input type="radio" class="btn-check" name="live_status" id="status-live" value="live">
                                                <label class="btn btn-outline-secondary btn-sm" for="status-live">
                                                    <i class="bi bi-circle-fill text-danger me-1 pulse-small"></i> Live
                                                </label>
                                                
                                                <input type="radio" class="btn-check" name="live_status" id="status-upcoming" value="upcoming">
                                                <label class="btn btn-outline-secondary btn-sm" for="status-upcoming">Upcoming</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- League Filter Column -->
                            <div class="col-md-6">
                                <div class="card card-filter">
                                    <div class="card-header py-2">
                                        <h6 class="mb-0"><i class="bi bi-trophy me-1"></i> League / Region</h6>
                                    </div>
                                    <div class="card-body">
                                        {% if selected_sport %}
                                        <!-- League/Region Filter -->
                                        <div class="mb-0">
                                            <label for="league-filter" class="form-label fw-semibold small">
                                                <i class="bi bi-geo-alt me-1"></i> Filter by League
                                            </label>
                                            <select class="form-select form-select-sm" id="league-filter">
                                                <option value="">All Leagues ({{ classes | length }})</option>
                                                {% for cls in classes %}
                                                <option value="{{ cls.id }}">{{ cls.name }} ({{ cls.count }})</option>
                                                {% endfor %}
                                            </select>
                                            <div class="form-text small text-muted mt-2">
                                                <i class="bi bi-info-circle me-1"></i> Showing {{ event_count }} events
                                            </div>
                                        </div>
                                        {% else %}
                                        <div class="text-center text-muted py-3">
                                            <i class="bi bi-info-circle me-1"></i> Select a specific sport to filter by league
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Clear Filters Button -->
                        <div class="text-center mt-3">
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="clear-filters">
                                <i class="bi bi-x-circle me-1"></i> Clear All Filters
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="text-center mt-3 pt-3 border-top">
                    <span class="text-muted">Searching odds range:</span>
                    <span class="fw-bold text-secondary ms-2">{{ min_odds | round(precision=2) }} - {{ max_odds | round(precision=2) }}</span>
                    <span class="text-muted ms-3">|</span>
                    <span class="text-muted ms-3">Times shown in UTC+2</span>
                </div>
            </div>
        </div>

        {% if error %}
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Error:</strong> {{ error }}
        </div>
        {% endif %}

        <div id="results-section" class="results-container">
            <div id="loading-overlay" class="loading-overlay">
                <div class="loading-content">
                    <div class="loading-dice">
                        <img src="/static/dice.svg" class="dice-svg" alt="Loading...">
                    </div>
                    <div class="loading-text">Searching for bets<span class="loading-dots"><span></span><span></span><span></span></span></div>
                </div>
            </div>
            <div class="card shadow-sm card-dark">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Events</h5>
                <span class="badge bg-secondary">{{ event_count }} event{% if event_count != 1 %}s{% endif %} ({{ count }} market{% if count != 1 %}s{% endif %})</span>
            </div>
            <div class="card-body p-0">
                {% if grouped_events | length > 0 %}
                <div class="accordion accordion-flush" id="eventsAccordion">
                    {% for event in grouped_events %}
                    <div class="accordion-item {% if event.is_live %}live-event{% endif %}" 
                         data-event-id="{{ event.event_id }}"
                         data-category-id="{{ event.category_id }}"
                         data-category-name="{{ event.category_name | escape }}"
                         data-class-id="{{ event.class_id }}"
                         data-class-name="{{ event.class_name | escape }}"
                         data-is-live="{{ event.is_live }}"
                         data-event-time-utc="{{ event.event_time_utc }}">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed {% if event.is_live %}live-header{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#event-{{ event.event_id }}" aria-expanded="false">
                                <div class="event-header-content">
                                    <div class="event-info">
                                        {% if event.is_live %}
                                        <span class="live-badge me-2">
                                            <i class="bi bi-circle-fill pulse me-1"></i>LIVE
                                            {% if event.match_minute %}<span class="match-minute">{{ event.match_minute }}'</span>{% endif %}
                                        </span>
                                        {% endif %}
                                        <span class="sport-badge me-2">{{ event.category_name }}</span>
                                        <span class="league-badge me-2">{{ event.class_name }}</span>
                                        <a href="{{ event.event_url }}" target="_blank" class="event-link" onclick="event.stopPropagation()">
                                            {{ event.event_name }} <i class="bi bi-box-arrow-up-right small"></i>
                                        </a>
                                    </div>
                                    <div class="event-meta">
                                        <span class="event-time">
                                            <i class="bi bi-clock me-1"></i>{{ event.event_time }}
                                        </span>
                                        <span class="market-count badge bg-secondary ms-2">
                                            {{ event.markets | length }} market{% if event.markets | length != 1 %}s{% endif %}
                                        </span>
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="event-{{ event.event_id }}" class="accordion-collapse collapse" data-bs-parent="#eventsAccordion">
                            <div class="accordion-body p-0">
                                <div class="market-table-controls d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                                    <button type="button" class="btn btn-sm btn-outline-secondary market-group-toggle" aria-pressed="false">
                                        <i class="bi bi-collection me-1"></i>Group by type
                                    </button>
                                </div>
                                <table class="table table-sm table-striped mb-0 market-table">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="sort-header" data-sort-col="market" role="button" tabindex="0" aria-sort="none">
                                                Market <i class="bi bi-arrow-down-up sort-icon ms-1"></i>
                                            </th>
                                            <th class="sort-header" data-sort-col="outcome" role="button" tabindex="0" aria-sort="none">
                                                Outcome <i class="bi bi-arrow-down-up sort-icon ms-1"></i>
                                            </th>
                                            <th class="sort-header text-end" data-sort-col="odds" role="button" tabindex="0" aria-sort="none">
                                                Odds <i class="bi bi-arrow-down-up sort-icon ms-1"></i>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for market in event.markets %}
                                        <tr data-event-id="{{ event.event_id }}"
                                            data-market-name="{{ market.market_name | escape }}"
                                            data-market-type="{{ market.market_type | escape }}"
                                            data-market-sub-type="{{ market.market_sub_type | escape }}"
                                            data-outcome="{{ market.outcome | escape }}"
                                            data-decimal="{{ market.decimal }}">
                                            <td>{{ market.market_name }}</td>
                                            <td>{{ market.outcome }}</td>
                                            <td class="text-end fw-bold text-success">{{ market.decimal | round(precision=2) }}</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="empty-state">
                    <img src="/static/empty-state.svg" alt="No results" class="empty-state-icon">
                    <h5>No bets found</h5>
                    <p>Try adjusting the target odds or increasing the tolerance.</p>
                </div>
                {% endif %}
            </div>
        </div>
        </div>

        <footer class="text-center mt-4 pt-3 border-top">
            <a href="/api/bets?target={{ target }}&tolerance={{ tolerance }}{% if selected_sport %}&sport={{ selected_sport }}{% endif %}" target="_blank" class="text-decoration-none">
                <i class="bi bi-braces me-1"></i> API Endpoint (JSON)
            </a>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/script.js"></script>
</body>
</html>
